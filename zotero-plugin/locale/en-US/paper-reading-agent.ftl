# Localization for the item-pane chat section.
# Registered automatically by Zotero from locale/<locale>/*.ftl and injected into
# each main window via MozXULElement.insertFTLIfNeeded (see bootstrap.js).
# header -> the collapsible-section .label; sidenav -> the sidenav button .tooltiptext
# (mirrors Zotero's built-in section-*/sidenav-* entries).

paper-reading-agent-header =
    .label = Codex Chat
paper-reading-agent-sidenav =
    .tooltiptext = Codex Chat
